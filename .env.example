# ===== Chat-iK server configuration =====

# Public domain (without protocol), used for TURN and links
APP_DOMAIN=chat.example.com

# PostgreSQL
POSTGRES_USER=chatik
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=chatik

# MinIO
MINIO_ROOT_USER=chatik_minio
MINIO_ROOT_PASSWORD=change_this_minio_password
MINIO_BUCKET=chatik

# App security
JWT_SECRET=change_this_jwt_secret_long_random
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@chat.example.com

# TURN
TURN_REALM=chat.example.com
TURN_EXTERNAL_IP=
TURN_USERNAME=chatik_turn
TURN_PASSWORD=change_this_turn_password